# ============================================
# WeedMusic Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values.
# All Firebase fields are OPTIONAL — the app works fully offline without them.

# ----- Database (Required) -----
DATABASE_URL=file:./db/custom.db

# ----- Firebase Authentication (Optional) -----
# Get these from: https://console.firebase.google.com
# Project Settings > General > Your apps > Web app

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ----- How to set up Firebase (Free, 5 minutes) -----
# 1. Go to https://console.firebase.google.com
# 2. Click "Add project" — name it "weedmusic"
# 3. Click the </> icon to create a Web App
# 4. Copy the config values above
# 5. Enable Google Authentication:
#    - Authentication > Sign-in method > Google > Enable
# 6. Create Realtime Database:
#    - Realtime Database > Create Database > Start in test mode
# 7. Copy the database URL to NEXT_PUBLIC_FIREBASE_DATABASE_URL

# ----- Supabase (Optional - replaces Firebase) -----
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Google AdSense (Optional) -----
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=
NEXT_PUBLIC_GOOGLE_ADSENSE_SLOT=

# ----- Deployment (Optional) -----
# VERCEL_TOKEN=your_vercel_token
